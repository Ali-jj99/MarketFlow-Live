# MarketFlow Live — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Database URL (SQLite for dev, swap to PostgreSQL for production)
DATABASE_URL=sqlite:///./marketflow.db
# DATABASE_URL=postgresql://user:password@localhost:5432/marketflow

# Secret key for future JWT session tokens
SECRET_KEY=replace_with_a_long_random_secret_string

# CoinGecko API key (free tier works without one; add key for higher rate limits)
COINGECKO_API_KEY=

# Future premium data API keys — all market calls stay in the backend only
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
